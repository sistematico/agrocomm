{
  "name": "agrocomm",
  "version": "1.0.2",
  "author": "Lucas Saliés Brum <paxa@paxa.dev> (https://paxa.dev)",
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "dev": "bun run --cwd apps/site dev",
    "apidev": "bun run --hot apps/api/src/index.ts",
    "api:install": "cd apps/api && bun install",
    "api:init": "cd apps/api && bun run init",
    "api:reset": "cd apps/api && bun run reset",
    "api:scrape": "cd apps/api && bun run scrape",
    "site:install": "cd apps/site && bun install",
    "site:build": "cd apps/site && bun run build",
    "clean": "rm -rf node_modules bun.lockb apps/*/node_modules apps/*/bun.lockb"
  },
  "devDependencies": {
    "bun-types": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.4.3"
  },
  "dependencies": {
    "cheerio": "^1.0.0-rc.12",
    "dayjs": "^1.11.10",
    "geoip-lite": "^1.4.10"
  }
}