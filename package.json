{
  "name": "agrocomm",
  "version": "1.0.0",
  "author": "Lucas Saliés Brum <paxa@paxa.dev> (https://paxa.dev)",
  "type": "module",
  "workspaces": ["apps/*"],
  "scripts": {
    "api:install": "cd apps/api && bun install",
    "api:reset": "cd apps/api && bun run freset",
    "site:install": "cd apps/site && bun install",
    "site:build": "cd apps/site && bun run build",
    "clean": "rm -rf node_modules bun.lockb apps/*/node_modules apps/*/bun.lockb"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "autoprefixer": "^10.4.16",
    "bun-types": "latest",
    "postcss": "^8.4.33",
    "prisma": "latest",
    "tailwindcss": "^3.4.1"
  },
  "peerDependencies": {
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@prisma/client": "latest",
    "dayjs": "^1.11.10",
    "vue-router": "4"
  }
}