generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  usuario    String     @unique
  email      String     @unique
  senha      String
  nome       String?
  cargo      Cargo      @default(USUARIO)
  assinatura Assinatura @default(GRATIS)
}

model Commodity {
  id       Int       @id @default(autoincrement())
  nome     String    @unique
  cotacoes Cotacao[]
}

model Cotacao {
  id          Int       @id @default(autoincrement())
  data        DateTime  @db.Date
  preco       Int?
  commodity   Commodity @relation(fields: [commodityId], references: [id])
  estado      String
  estados     Estado    @relation(fields: [estado], references: [sigla])
  cidadeId    Int
  cidades     Cidade    @relation(fields: [cidadeId], references: [id])
  commodityId Int
}

model Estado {
  id       Int       @id @default(autoincrement())
  nome     String
  sigla    String    @unique
  cidades  Cidade[]
  cotacoes Cotacao[]
}

model Cidade {
  id       Int       @id @default(autoincrement())
  nome     String
  estados  Estado    @relation(fields: [estado], references: [sigla])
  estado   String
  cotacoes Cotacao[]

  //@@id([nome, estado])
}

enum Cargo {
  USUARIO
  ADMIN
  MODERADOR
  SUPERADMIN
}

enum Assinatura {
  GRATIS
  BASICA
  BRONZE
  PRATA
  OURO
  DIAMANTE
}
