{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "bun:dev - site",
			"type": "npm",
			"script": "dev",
			"path": "apps/site",
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			},
			"presentation": {
				"echo": true,
				"reveal": "never",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": false,
				"clear": true
			}
		},
		{
			"label": "bun:dev - api",
			"type": "npm",
			"script": "dev",
			"path": "apps/api",
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			}
		},
		{
			"label": "bun:studio - api",
			"type": "npm",
			"script": "studio",
			"path": "apps/api",
			"problemMatcher": [],
			"runOptions": {
				"runOn": "folderOpen"
			},
			"presentation": {
				"echo": true,
				"reveal": "never",
				"focus": false,
				"panel": "shared",
				"showReuseMessage": true,
				"clear": false
			}
		},
		{
			"label": "podman:start",
			"type": "shell",
			"command": "${workspaceFolder}/scripts/container.sh",
			"problemMatcher": [],
			"isBackground": true,
			"promptOnClose": false
		},
		{
			"label": "Run Ansible Playbook",
			"type": "shell",
			"command": "ansible-playbook",
			"args": [
				"-i",
				"eris.paxa.dev,",
				"ansible/playbook.yml"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "new"
			}
		}
	]
}







